---
import { getCollection } from 'astro:content';
import siteData from '../data/site.json';

const posts = await getCollection('blog');
posts.sort((a, b) => new Date(b.data.date).getTime() - new Date(a.data.date).getTime());

function formatDate(ts: Date): string {
  return ts.toLocaleDateString('en-US', { year: 'numeric', month: 'short', day: 'numeric' });
}
---

<section id="blog">
  <div class="container">
    <div class="section-header">
      <div>
        <p class="section-tag" data-i18n="blog_tag">03 · Blog</p>
        <h2 class="section-title" style="margin-bottom:0;" data-i18n="blog_title">Blog</h2>
      </div>
      <div style="display:flex;gap:0.8rem;align-items:center;">
        <a href="/blog" class="btn-outline" data-i18n="browse_all2">🔍 Browse All</a>
      </div>
    </div>

    <div class="blog-list">
      {posts.length === 0
        ? <p style="text-align:center;color:var(--text-muted);padding:3rem;">No posts yet.</p>
        : posts.slice(0, 5).map(post => (
            <a href={`/blog/${post.slug}`} class="blog-card">
              <div class="blog-date">{formatDate(post.data.date)}</div>
              <div class="blog-info">
                <h3>{post.data.title}</h3>
                <p>{post.data.excerpt}</p>
                {post.data.tags && post.data.tags.length > 0 && (
                  <div class="blog-meta">
                    {post.data.tags.map(tag => <span class="tag">{tag}</span>)}
                  </div>
                )}
              </div>
              <div class="blog-arrow">&rarr;</div>
            </a>
          ))
      }
    </div>
  </div>
</section>
