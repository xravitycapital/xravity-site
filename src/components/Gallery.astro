---
import siteData from '../data/site.json';
const photos = siteData.gallery.photos || [];
---

<section id="gallery">
  <div class="container">
    <div class="section-header">
      <div>
        <p class="section-tag" data-i18n="gallery_tag">02 · Gallery</p>
        <h2 class="section-title" style="margin-bottom:0;" data-i18n="gallery_title">
          {siteData.gallery.title}
        </h2>
      </div>
    </div>
    <p class="section-subtitle" data-i18n="gallery_sub">
      {siteData.gallery.sub}
    </p>

    <div class="gallery-grid" id="galleryGrid">
      {photos.length === 0
        ? <div class="gallery-item" style="display:flex;align-items:center;justify-content:center;flex-direction:column;gap:0.8rem;color:var(--text-light);font-family:var(--font-mono);font-size:0.8rem;">
            <span style="font-size:2.2rem;font-weight:300;">+</span>
            <span>Photos coming soon</span>
          </div>
        : photos.map(photo => (
            <div class="gallery-item">
              <img src={photo.src} alt={photo.caption || ''} loading="lazy" />
              <div class="gallery-item-info">
                <span>{photo.caption || 'Untitled'}</span>
              </div>
            </div>
          ))
      }
    </div>
  </div>
</section>

<!-- Lightbox -->
<div class="lightbox" id="lightbox">
  <button class="lightbox-close" id="lightboxClose">&times;</button>
  <button class="lightbox-nav lightbox-prev" id="lightboxPrev">&lsaquo;</button>
  <button class="lightbox-nav lightbox-next" id="lightboxNext">&rsaquo;</button>
  <img id="lightboxImg" src="" alt="Lightbox preview" />
  <div class="lightbox-caption" id="lightboxCaption" style="display:none;"></div>
</div>

<script>
  const lightbox = document.getElementById('lightbox')!;
  const lightboxImg = document.getElementById('lightboxImg') as HTMLImageElement;
  const lightboxCaption = document.getElementById('lightboxCaption')!;
  const lightboxClose = document.getElementById('lightboxClose')!;
  const lightboxPrev = document.getElementById('lightboxPrev')!;
  const lightboxNext = document.getElementById('lightboxNext')!;

  // Build photo list from gallery items
  const photoItems = Array.from(document.querySelectorAll('.gallery-item img')).map(img => ({
    src: (img as HTMLImageElement).src,
    caption: (img.parentElement?.querySelector('.gallery-item-info span') as HTMLElement)?.textContent || ''
  }));
  let currentIdx = 0;

  function showPhoto(idx: number) {
    if (photoItems.length === 0) return;
    currentIdx = ((idx % photoItems.length) + photoItems.length) % photoItems.length;
    const photo = photoItems[currentIdx];
    lightboxImg.src = photo.src;
    if (photo.caption) {
      lightboxCaption.textContent = photo.caption;
      lightboxCaption.style.display = 'block';
    } else {
      lightboxCaption.style.display = 'none';
    }
    // Toggle arrows visibility
    (lightboxPrev as HTMLElement).style.display = photoItems.length > 1 ? 'flex' : 'none';
    (lightboxNext as HTMLElement).style.display = photoItems.length > 1 ? 'flex' : 'none';
  }

  document.querySelectorAll('.gallery-item img').forEach((img, idx) => {
    img.addEventListener('click', () => {
      lightbox.classList.add('active');
      showPhoto(idx);
    });
  });

  lightboxPrev.addEventListener('click', () => showPhoto(currentIdx - 1));
  lightboxNext.addEventListener('click', () => showPhoto(currentIdx + 1));

  function closeLightbox() { lightbox.classList.remove('active'); }
  lightboxClose.addEventListener('click', closeLightbox);
  lightbox.addEventListener('click', e => { if (e.target === lightbox) closeLightbox(); });
  document.addEventListener('keydown', e => {
    if (e.key === 'Escape') closeLightbox();
    if (e.key === 'ArrowLeft' && lightbox.classList.contains('active')) showPhoto(currentIdx - 1);
    if (e.key === 'ArrowRight' && lightbox.classList.contains('active')) showPhoto(currentIdx + 1);
  });
</script>
